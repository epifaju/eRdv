# Copier vers .env à la racine du projet (non versionné) :
#   Copy-Item .env.example .env
# Ou lancer : .\scripts\generate-docker-env.ps1
#
# Variables utilisées par docker-compose.yml

JWT_EXPIRATION=86400000
# Durée du refresh token (ms), ex. 7 jours
JWT_REFRESH_EXPIRATION=604800000

# Mot de passe PostgreSQL (service postgres + backend)
POSTGRES_PASSWORD=password
# Port hôte PostgreSQL (5436 si 5433 est déjà pris par un autre conteneur)
POSTGRES_HOST_PORT=5436

# Obligatoire pour le backend en prod — généré par generate-docker-env.ps1
JWT_SECRET=

# true = comptes test (admin@erdv.com, user@erdv.com) au démarrage — false en prod réelle
APP_SEED_DEMO_USERS=true

# SMTP (optionnel)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=epifaju@gmail.com
SPRING_MAIL_PASSWORD=

# URL du frontend (liens dans les e-mails)
APP_FRONTEND_BASE_URL=http://localhost:3001

# Rappels automatiques J-1 / H-2
APP_REMINDERS_ENABLED=true

# Annulation client : minimum X heures avant le RDV
APP_RDV_DELAI_ANNULATION_HEURES=24

# Swagger UI (true en dev / Docker local)
APP_OPENAPI_ENABLED=true

# Paiement en ligne Stripe (false = réservation classique sans paiement)
APP_PAYMENT_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Secret webhook Stripe CLI : stripe listen --forward-to localhost:8084/api/payments/webhook
STRIPE_WEBHOOK_SECRET=

# Rate limiting auth (tentatives par IP)
APP_AUTH_RATE_LIMIT_ENABLED=true
APP_AUTH_RATE_LIMIT_MAX=20
APP_AUTH_RATE_LIMIT_WINDOW=60

# Purge refresh tokens expirés / révoqués (cron Spring : sec min hour day month weekday)
APP_AUTH_REFRESH_TOKEN_PURGE_ENABLED=true
APP_AUTH_REFRESH_TOKEN_PURGE_CRON=0 0 3 * * *

# Logs : profil prod seul = JSON ; prod,plain-logs = texte lisible (défaut Docker local)
# SPRING_PROFILES_ACTIVE=prod
