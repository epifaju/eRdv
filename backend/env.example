# Copier vers .env (non versionné) ou définir dans l’orchestrateur / le PaaS.
# Production : aucun secret ne doit rester dans le dépôt Git.

# Profil Spring : dev (local) | prod
SPRING_PROFILES_ACTIVE=prod

# Base PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/erdv_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=changeme

# JWT — obligatoire en prod, minimum ~32 caractères pour HS256
JWT_SECRET=
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# SMTP (optionnel au démarrage ; requis pour les e-mails réels)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=epifaju@gmail.com
SPRING_MAIL_PASSWORD=

# CORS : motifs séparés par des virgules (ex. https://app.example.com,https://www.example.com)
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*

# Port HTTP du serveur (optionnel)
SERVER_PORT=8080

# Comptes de démo au démarrage (admin@erdv.com, user@erdv.com) — false en prod réelle
APP_SEED_DEMO_USERS=false

# URL du frontend (liens e-mail mot de passe oublié)
APP_FRONTEND_BASE_URL=http://localhost:3001

# Sauvegardes PostgreSQL : planifier des pg_dump (cron, tâche orchestrateur, etc.)
